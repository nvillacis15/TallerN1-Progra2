package interfaz;

import java.util.Scanner;
import negocio.PerfilMedico;

public class PruebaPerfilMedico {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Nombre: ");
        String nombre = sc.nextLine();

        System.out.print("Apellido: ");
        String apellido = sc.nextLine();

        System.out.print("Sexo: ");
        String sexo = sc.nextLine();

        System.out.print("Día: ");
        int dia = Integer.parseInt(sc.nextLine());

        System.out.print("Mes: ");
        int mes = Integer.parseInt(sc.nextLine());

        System.out.print("Año: ");
        int año = Integer.parseInt(sc.nextLine());

        System.out.print("Altura (cm): ");
        double altura = Double.parseDouble(sc.nextLine());

        System.out.print("Peso (kg): ");
        double peso = Double.parseDouble(sc.nextLine());

        PerfilMedico persona = new PerfilMedico(
                nombre, apellido, sexo, dia, mes, año, altura, peso);


        System.out.println("\n--- INFORMACIÓN ---");
        System.out.println("Nombre: " + persona.getNombre() + " " + persona.getApellido());
        System.out.println("Sexo: " + persona.getSexo());
        System.out.println("Fecha: " + persona.getDia() + "/" + persona.getMes() + "/" + persona.getAño());
        System.out.println("Altura: " + persona.getAltura() + " cm");
        System.out.println("Peso: " + persona.getPeso() + " kg");


        System.out.println("\n--- RESULTADOS ---");
        System.out.println("Edad: " + persona.calcularEdad());
        System.out.println("Frecuencia máxima: " + persona.frecuenciaMaxima());
        System.out.println("Rango esperado: " + persona.frecuenciaEsperada());
        System.out.println("BMI: " + String.format("%.2f", persona.calcularBMI()));
        System.out.println("Clasificación BMI: " + persona.clasificacionBMI());


        System.out.println("\n--- TABLA BMI ---");
        System.out.println("Bajo peso: menos de 18.5");
        System.out.println("Normal: 18.5 - 24.9");
        System.out.println("Sobrepeso: 25 - 29.9");
        System.out.println("Obeso: 30 o más");

        sc.close();
    }
}



//// negocio
package negocio;

import java.time.LocalDate;
import java.time.Period;

public class PerfilMedico {

    private String nombre;
    private String apellido;
    private String sexo;
    private int dia, mes, año;
    private double altura; // cm
    private double peso;   // kg


    public PerfilMedico(String nombre, String apellido, String sexo,
                        int dia, int mes, int año,
                        double altura, double peso) {

        this.nombre = nombre;
        this.apellido = apellido;
        this.sexo = sexo;
        this.dia = dia;
        this.mes = mes;
        this.año = año;
        this.altura = altura;
        this.peso = peso;
    }


    public String getNombre() { return nombre; }
    public String getApellido() { return apellido; }
    public String getSexo() { return sexo; }
    public int getDia() { return dia; }
    public int getMes() { return mes; }
    public int getAño() { return año; }
    public double getAltura() { return altura; }
    public double getPeso() { return peso; }

    public void setNombre(String nombre) { this.nombre = nombre; }
    public void setApellido(String apellido) { this.apellido = apellido; }
    public void setSexo(String sexo) { this.sexo = sexo; }
    public void setDia(int dia) { this.dia = dia; }
    public void setMes(int mes) { this.mes = mes; }
    public void setAño(int año) { this.año = año; }
    public void setAltura(double altura) { this.altura = altura; }
    public void setPeso(double peso) { this.peso = peso; }


    public int calcularEdad() {
        LocalDate nacimiento = LocalDate.of(año, mes, dia);
        return Period.between(nacimiento, LocalDate.now()).getYears();
    }


    public int frecuenciaMaxima() {
        return 220 - calcularEdad();
    }


    public String frecuenciaEsperada() {
        int max = frecuenciaMaxima();
        return String.format("%.2f - %.2f", max * 0.50, max * 0.85);
    }


    public double calcularBMI() {
        double alturaMetros = altura / 100.0;
        return peso / (alturaMetros * alturaMetros);
    }


    public String clasificacionBMI() {
        double bmi = calcularBMI();

        if (bmi < 18.5) return "Bajo peso";
        else if (bmi < 25) return "Normal";
        else if (bmi < 30) return "Sobrepeso";
        else return "Obeso";
    }
}
